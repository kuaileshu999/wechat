# 复制为 deploy/.env 后修改（不要提交 .env 到 Git）

# 服务器公网 IP 或域名
DEPLOY_HOST=120.26.194.111

# 项目根目录（服务器上 git clone 的路径）
PROJECT_ROOT=/root/wechat

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=wechat
DB_USER=wechat
DB_PASSWORD=请改成宝塔数据库密码

# 前端访问地址（CORS，多个用英文逗号分隔）
CORS_ORIGINS=http://120.26.194.111

# Java 启动参数
JAVA_OPTS="-Xms256m -Xmx512m"

# 后端 jar 运行端口
SERVER_PORT=8080
